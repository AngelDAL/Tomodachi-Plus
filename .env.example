# Tomodachi POS - Variables de Entorno
# Copia este archivo a .env y completa tus valores

# === Base de Datos ===
DB_HOST=localhost
DB_NAME=tomodachi_dev
DB_USER=tomodachi
DB_PASS=tomodachi_dev_2026
DB_CHARSET=utf8mb4

# === Entorno ===
# development | production | testing
APP_ENV=development
APP_MODE=SAAS
DEBUG_MODE=true

# === API Keys - IA ===
# Google Gemini (https://aistudio.google.com/)
GOOGLE_GEMINI_API_KEY=
# Stability AI (https://platform.stability.ai/)
STABILITY_AI_API_KEY=

# === SMTP / Correo ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tomodachi.pos
SMTP_FROM_NAME=Tomodachi POS

# === Seguridad ===
SESSION_LIFETIME=86400
SESSION_NAME=tomodachi_session
ALLOWED_ORIGINS=http://localhost,http://localhost:8080,https://*.tomodachi.app

# === Rate Limiting ===
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
