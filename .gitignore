# Tomodachi POS - Git Ignore

# Variables de entorno
.env
.env.local
.env.production

# Archivos de configuración sensibles
config/database.php
config/mail.php

# Archivos de sistema
.DS_Store
Thumbs.db
*.log

# Directorios temporales
/temp/
/cache/
/uploads/

# Imágenes de productos (generadas dinámicamente)
public/assets/images/products/
public/assets/images/logos/

# Archivos de IDE
.vscode/
.idea/
*.sublime-*

# Dependencias
/vendor/
/node_modules/
composer.phar
composer.lock

# Archivos de backup
*.bak
*.backup
*.old
database/backups/*.sql

# Configuración de IA (contiene API keys)
api/ai/config.php

# Archivos debug (no deberían estar en producción)
debug_*.php
test_*.php
repro_issue.php
check_insert.php
